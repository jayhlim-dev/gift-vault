# Firebase client SDK config (safe to expose to the browser, from Project settings -> General -> Your apps)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK credentials
# Get these from Firebase Console -> Project settings -> Service accounts -> Generate new private key.
# The downloaded JSON file contains project_id, client_email and private_key.

# Google Cloud Storage bucket for avatar uploads (recommended - no Firebase Storage needed).
# Create in Google Cloud Console -> Cloud Storage -> Buckets, then grant your service account
# (FIREBASE_CLIENT_EMAIL) the "Storage Object Admin" role on that bucket.
GCS_BUCKET_NAME=

# Optional fallback if not using GCS_BUCKET_NAME (requires Firebase Storage to be enabled).
FIREBASE_STORAGE_BUCKET=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the surrounding quotes and \n line breaks exactly as they appear in the downloaded JSON.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
